<Window x:Class="NAPClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NAPClient" Height="600" Width="640"
        WindowStartupLocation="Manual"
        Top="200" Left="1300"
        Closing="MainWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400*" />
            <ColumnDefinition Width="240*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="APConnection" Grid.Row="0" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0">URL:</Label>
            <Label Grid.Row="1">Slot Name:</Label>
            <Label Grid.Row="2">Password:</Label>

            <TextBox Grid.Row="0" Grid.Column="1" x:Name="UrlEntry"></TextBox>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="SlotNameEntry"></TextBox>
            <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="PasswordEntry"></PasswordBox>

            <Button Grid.Row="3" Grid.ColumnSpan="2" Click="ConnectToServerPressed" Tag="Connect">Connect</Button>
        </Grid>

        <Grid x:Name="LocalRando" Grid.Row="0" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0">File Path:</Label>
            <Button Grid.Row="0" Grid.Column="1" Click="BrowseLocalFiles">Browse</Button>
            <TextBox Grid.Row="0" Grid.Column="2" x:Name="FilePath"></TextBox>
            
            <Button Grid.Row="1" Grid.ColumnSpan="3" Click="LoadLocalRandoFile">Load File</Button>
        </Grid>
        
        <Label Grid.Row="1">Level Grid</Label>
        <Grid Grid.Row="2" x:Name="LevelGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="72"/>
                <RowDefinition Height="72"/>
                <RowDefinition Height="72"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="72"/>
            </Grid.ColumnDefinitions>
        </Grid>
        <Grid Grid.Row="3" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Label Grid.Row="0" Grid.Column="0">Level Name: </Label>
            <Label Grid.Row="1" Grid.Column="0">Level ID:</Label>
            <Label Grid.Row="2" Grid.Column="0">Available? </Label>
            <Label Grid.Row="3" Grid.Column="0">G++? </Label>
            <Label Grid.Row="0" Grid.Column="1" x:Name="LevelNameLabel">--</Label>
            <Label Grid.Row="1" Grid.Column="1" x:Name="LevelIDLabel">--</Label>
            <Label Grid.Row="2" Grid.Column="1" x:Name="AvailableLabel">--</Label>
            <Label Grid.Row="3" Grid.Column="1" x:Name="AllGoldLabel">--</Label>
        </Grid>
        
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,0,5,0">
            <Button x:Name="BtnAdd" Margin="0,5,0,0" Click="HookToGameButtonPressed" IsEnabled="False">Hook To Game</Button>
            <Button x:Name="BtnUpdateValues" Click="ApplyStartTimeValueButtonPressed" Content="Update Values"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label Grid.Row="1" x:Name="StartTimeLabel" Grid.ColumnSpan="3">Start Time:</Label>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="StartTimeEntry" Grid.ColumnSpan="3" Margin="0,0,3,0"></TextBox>
                <Label Grid.Row="2" x:Name="GoldValueLabel" Grid.ColumnSpan="3">Gold Value:</Label>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="GoldValueEntry" Grid.ColumnSpan="3" Margin="0,0,3,0"></TextBox>
            </Grid>
            <Button x:Name="BtnSwapLevels" Margin="0,5,0,0" Click="SwapTwoLevelsButtonPressed">Swap Levels</Button>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label HorizontalAlignment="Center" Grid.ColumnSpan="4">Levels to swap</Label>
                <Label Grid.Row="1" x:Name="FirstLevelLabel" Grid.ColumnSpan="3">First Level:</Label>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="FirstLevelEntry" Grid.ColumnSpan="3" Margin="0,0,3,0"></TextBox>
                <Label Grid.Row="2" x:Name="SecondLevelLabel" Grid.ColumnSpan="3">Second Level:</Label>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="SecondLevelEntry" Grid.ColumnSpan="3" Margin="0,0,3,0"></TextBox>
            </Grid>
            <Button x:Name="BtnCycleLevelStatus" Margin="0,5,0,0" Click="CycleLevelStatusPressed">Cycle Level Status</Button>
            <Button x:Name="BtnUpdateLevelStatus" Margin="0,5,0,0" Click="UpdateLevelStatusPressed">Update Level Completion</Button>

        </StackPanel>
    </Grid>
</Window>